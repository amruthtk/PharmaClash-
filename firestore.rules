rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — authenticated users can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow any authenticated user to read another user's public info
      // (needed for caregiver linking to get patient/caregiver name)
      allow read: if request.auth != null;

      // Allow linked caregivers/patients to update linked arrays
      allow update: if request.auth != null;

      // User medicines sub-collection
      match /medicines/{medicineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Dose logs sub-collection
      match /dose_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Adherence sub-collection
      match /adherence/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Medical info — owner only
    match /medical_info/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Drugs collection — allow authenticated read
    match /drugs/{drugId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Drug interactions — allow authenticated read
    match /drug_interactions/{interactionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── CAREGIVER NOTIFICATIONS ───

    // Link codes — any authenticated user can create/read
    match /caregiver_links/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Caregiver alerts — owner can read/write their own alerts
    // Patient can write alerts to any caregiver (via linked caregivers)
    match /caregiver_alerts/{caregiverUid}/alerts/{alertId} {
      // Caregiver can read and update (mark read) their own alerts
      allow read, update: if request.auth != null && request.auth.uid == caregiverUid;
      // Any authenticated user can create alerts (patient sending to caregiver)
      allow create: if request.auth != null;
    }

    // Admin audit logs
    match /admin_audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Guest telemetry — any authenticated user can create/read
    match /guest_telemetry/{logId} {
      allow create, read: if request.auth != null;
    }
  }
}
